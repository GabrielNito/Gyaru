generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String?
  userEmail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cards       Card[]
}

model Card {
  id        String   @id @default(cuid())
  front     String
  back      String
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
